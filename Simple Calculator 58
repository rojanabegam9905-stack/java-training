import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int a,b;
        Scanner mr=new Scanner(System.in);
        a=mr.nextInt();
        b=mr.nextInt();
        int sum=a+b;
        int difference=a-b;
        int product=a*b;
        int quotient=a/b;
        System.out.println(sum);
        System.out.println(difference);
        System.out.println(product);
        System.out.println(quotient);
        
    }
}
